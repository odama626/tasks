{
  "imports": {
    "$": "./",
    "hono": "https://deno.land/x/hono@v3.9.2/mod.ts",
    "dotenv": "https://deno.land/std@0.205.0/dotenv/mod.ts",
    "postgresjs": "https://deno.land/x/postgresjs/mod.js",
    "pgmg": "npm:pgmg@0.0.11"
  },
  "tasks": {
    "dev": "deno run --allow-read --allow-env --allow-net --watch ./src/main.ts",
    "migrate-db": "deno run --allow-read --allow-env --allow-net migrate.ts 'postgres://user:admin@localhost:5432/pub_server' $(ls -1 migrations | sed 's/.*/migrations\\/&/')"
  }
}