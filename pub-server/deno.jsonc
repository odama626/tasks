{
	"imports": {
		"./": "./",
		"/": "./src/",
		"/routes/": "./src/routes/",
		"hono": "https://deno.land/x/hono@v3.9.2/mod.ts",
		"postgresjs": "https://deno.land/x/postgresjs@v3.4.3/mod.js",
		"pgmg": "npm:pgmg@0.0.11",
		"@hono/zod-validator": "npm:@hono/zod-validator@0.1.11",
		"zod": "https://deno.land/x/zod@v3.22.4/mod.ts",
		"argon2": "https://deno.land/x/argon2ian@2.0.1/src/async.ts",
		"std/encoding/hex": "https://deno.land/std@0.192.0/encoding/hex.ts",
		"rsa": "https://deno.land/x/rsa@v0.2/mod.ts",
		"std/": "https://deno.land/std@0.205.0/"
	},
	"tasks": {
		"dev": "deno run --allow-read --allow-env --allow-net --watch ./src/main.ts",
		"migrate-db": "sh -c 'source ./.env.defaults set; source ./.env set; deno run --allow-read --allow-env --allow-net migrate.ts $POSTGRES_CONNECTION $(ls -1 migrations | sed \"s/.*/migrations\\/&/\")'",
		"ci-migrate-db": "deno run --allow-read --allow-env --allow-net migrate.ts $POSTGRES_CONNECTION $(ls -1 migrations | sed \"s/.*/migrations\\/&/\")",
		"start": "sh -c './startup.sh'",
		"test": "deno test --allow-read --allow-env --allow-net"
	}
}
